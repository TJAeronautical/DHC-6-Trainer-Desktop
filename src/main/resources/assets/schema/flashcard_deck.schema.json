{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://dhc6trainer.app/schema/flashcard_deck.schema.json",
  "title": "DHC-6 Flashcard Deck",
  "description": "A deck of study flashcards. Every card MUST carry at least one source citation; cards without citations fail content validation.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaId",
    "schemaVersion",
    "deckId",
    "deckName",
    "systemId",
    "variant",
    "cards"
  ],
  "properties": {
    "schemaId": {
      "type": "string",
      "const": "flashcard_deck"
    },
    "schemaVersion": {
      "type": "string",
      "enum": ["1.0.0"]
    },
    "deckId": {
      "type": "string",
      "pattern": "^[a-z0-9_]+$"
    },
    "deckName": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "systemId": {
      "type": "string",
      "pattern": "^[a-z0-9_]+$",
      "description": "References a systemId in /assets/systems/."
    },
    "variant": {
      "type": "string",
      "enum": ["LEGACY", "G950", "BOTH"]
    },
    "difficulty": {
      "type": "string",
      "enum": ["BASICS", "INTERMEDIATE", "ADVANCED"]
    },
    "cards": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "front", "back", "references"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9_]+$"
          },
          "front": {
            "type": "string",
            "minLength": 1
          },
          "back": {
            "type": "string",
            "minLength": 1
          },
          "tags": {
            "type": "array",
            "items": { "type": "string" }
          },
          "appliesToVariant": {
            "type": "string",
            "enum": ["LEGACY", "G950", "BOTH"]
          },
          "references": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["source", "locator"],
              "properties": {
                "source": {
                  "type": "string",
                  "enum": ["POH_AFM", "FCTM", "QRH", "OPERATOR_OM", "MANUFACTURER_BULLETIN"]
                },
                "locator": { "type": "string", "minLength": 1 },
                "revision": { "type": "string" }
              }
            }
          }
        }
      }
    }
  }
}
