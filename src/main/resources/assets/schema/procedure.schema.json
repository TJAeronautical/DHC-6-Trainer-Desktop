{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://dhc6trainer.app/schema/procedure.schema.json",
  "title": "DHC-6 Procedure Definition",
  "type": "object",
  "oneOf": [
    {
      "title": "Legacy Single Procedure (v1)",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rawName",
        "category",
        "variant",
        "memory",
        "flow"
      ],
      "properties": {
        "schemaId": {
          "type": "string"
        },
        "schemaVersion": {
          "type": "string"
        },
        "rawName": {
          "type": "string",
          "minLength": 1
        },
        "category": {
          "type": "string",
          "minLength": 1
        },
        "variant": {
          "type": "string",
          "enum": [
            "LEGACY",
            "G950",
            "BOTH"
          ]
        },
        "memory": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/step"
          }
        },
        "flow": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/step"
          }
        }
      }
    },
    {
      "title": "Training Edition Envelope (v2)",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rawName",
        "category",
        "variants"
      ],
      "properties": {
        "schemaId": {
          "type": "string"
        },
        "schemaVersion": {
          "type": "string"
        },
        "rawName": {
          "type": "string",
          "minLength": 1
        },
        "category": {
          "type": "string",
          "minLength": 1
        },
        "variants": {
          "$ref": "#/definitions/variantsEnvelope"
        },
        "context": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "variants": {
              "$ref": "#/definitions/variantsEnvelope"
            }
          }
        }
      }
    }
  ],
  "definitions": {
    "crewRole": {
      "type": "string",
      "enum": [
        "PF",
        "PM",
        "BOTH"
      ]
    },
    "step": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "action"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "action": {
          "type": "string",
          "minLength": 1
        },
        "crewRole": {
          "$ref": "#/definitions/crewRole"
        },
        "targets": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "note": {
          "type": "string"
        },
        "callout": {
          "type": "string"
        }
      }
    },
    "procedureVariantBody": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "memory",
        "flow"
      ],
      "properties": {
        "memory": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/step"
          }
        },
        "flow": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/step"
          }
        }
      }
    },
    "variantsEnvelope": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "LEGACY": {
          "$ref": "#/definitions/procedureVariantBody"
        },
        "G950": {
          "$ref": "#/definitions/procedureVariantBody"
        }
      },
      "anyOf": [
        {
          "required": [
            "LEGACY"
          ]
        },
        {
          "required": [
            "G950"
          ]
        }
      ]
    }
  }
}
