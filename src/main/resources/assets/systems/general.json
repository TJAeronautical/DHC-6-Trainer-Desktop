          "locator": "Section 1.3.1, p.1-8"
        }
      ]
    },
    {
      "id": "certification",
      "name": "Type Certification",
      "description": "Certificated under Canadian Air Regulation (CAR) 3 and SFAR 23. Type Certificate issued by Transport Canada. FAA validation also held. DHC-6 Series 300 production covered serial numbers 231 onwards (approximately).",
      "references": [
        {
          "source": "POH_AFM",
