          "locator": "Section 1.4.2, p.1-9"
        }
      ]
    },
    {
      "id": "crew_pax",
      "name": "Crew and Passengers",
      "description": "Minimum crew: 1 pilot. Normal operations: 2 crew. Maximum passengers: 20. Cabin is equipped with 19 passenger seats in standard commuter configuration. Cargo operations also certified.",
      "specifications": {
        "min_crew": "1",
        "normal_crew": "2",
        "max_passengers": "20"
      },
      "references": [
