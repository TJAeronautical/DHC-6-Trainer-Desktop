    {
      "id": "engines_general",
      "name": "Engines",
      "description": "Two Pratt & Whitney Canada PT6A-27 free-turbine turboprop engines, flat-rated at 620 SHP to ISA+18\u00b0C. Engine Type Certificate DOT E6 / FAA E4EA. Some aircraft fitted with PT6A-34 (derated to 620 SHP).",
      "specifications": {
        "type": "PT6A-27 (or PT6A-34 derated)",
        "rated_shp": "620",
        "flat_rated_to": "ISA+18\u00b0C",
        "number_of_engines": "2"
      },
      "references": [
        {
