  "systemId": "general",
  "systemName": "General \u2014 Aircraft Specifications",
  "variant": "BOTH",
  "summary": "The de Havilland Canada DHC-6 Twin Otter Series 300 is an all-metal, high-wing, fixed-gear STOL commuter aircraft certificated for operation with up to 2 crew and 20 passengers. Powered by two PT6A-27 free-turbine turboprop engines flat-rated to 620 SHP. MTOW 12,500 lb. The aircraft is certified in several configurations: landplane (wheeled), floatplane (Wipline 13000), wheel-ski, and spring-ski. Type certificated under CAR 3 and SFAR 23.",
  "references": [
    {
      "source": "POH_AFM",
      "locator": "Section 1.3 Leading Particulars, p.1-8\u20139",
      "revision": "Rev 53 (10 Sep 2010)"
    },
    {
      "source": "POH_AFM",
      "locator": "Section 2 Limitations, p.2-1 to 2-30",
      "revision": "Rev 53 (10 Sep 2010)"
    },
    {
      "source": "QRH",
      "locator": "Section 11 Mass and Balance / Section 12 Speeds / Section 14 Misc Limitations",
      "revision": "HBFO-002 ISS 01 REV 02"
    }
  ],
  "components": [
    {
      "id": "airframe",
      "name": "Airframe",
      "description": "All-metal high-wing monoplane. Conventional three-control dual side-by-side rudder pedal and control column combination. Strut-braced wing. Fixed non-retractable tricycle landing gear (landplane). Semi-monocoque fuselage.",
      "specifications": {
        "wing_span_ft": "65",
        "length_ft_in": "51 ft 9 in",
        "tail_height_ft_in": "19 ft 6 in",
        "cabin_height_in": "9 ft 8 in (exterior)",
        "cabin_height_interior_ft_in": "4 ft 11 in",
        "cabin_length_ft_in": "18 ft 5 in",
        "wing_area_sq_ft": "420",
        "configuration": "High-wing monoplane, fixed tricycle gear"
      },
      "references": [
        {
          "source": "POH_AFM",
          "locator": "Section 1.3.2\u20131.4, p.1-8\u20139"
        }
