{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://dhc6trainer.app/schema/ai_extraction_job.schema.json",
  "title": "AI Extraction Job",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "job",
    "inputs",
    "outputs"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "enum": [
        "2.0"
      ]
    },
    "job": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "jobId",
        "createdAtUtc",
        "status"
      ],
      "properties": {
        "jobId": {
          "type": "string",
          "description": "UUID recommended."
        },
        "createdAtUtc": {
          "type": "string",
          "format": "date-time"
        },
        "startedAtUtc": {
          "type": "string",
          "format": "date-time"
        },
        "finishedAtUtc": {
          "type": "string",
          "format": "date-time"
        },
        "status": {
          "type": "string",
          "enum": [
            "QUEUED",
            "RUNNING",
            "SUCCEEDED",
            "FAILED",
            "PARTIAL"
          ]
        },
        "requestedBy": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "inputs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "documents"
      ],
      "properties": {
        "documents": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/definitions/sourceDocument"
          }
        },
        "variantTarget": {
          "type": "string",
          "enum": [
            "LEGACY",
            "G950",
            "BOTH"
          ]
        },
        "extract": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "procedures": {
              "type": "boolean"
            },
            "knowledgeUnits": {
              "type": "boolean"
            },
            "tables": {
              "type": "boolean"
            },
            "figures": {
              "type": "boolean"
            }
          }
        },
        "normalization": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "strictWording": {
              "type": "boolean"
            },
            "hyphenationFix": {
              "type": "boolean"
            },
            "whitespaceFix": {
              "type": "boolean"
            },
            "ocrFix": {
              "type": "boolean"
            }
          }
        }
      }
    },
    "outputs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifacts"
      ],
      "properties": {
        "artifacts": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/definitions/artifact"
          }
        },
        "compileTargets": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "emitRuntimeProcedures": {
              "type": "boolean"
            },
            "emitCockpitBindings": {
              "type": "boolean"
            },
            "emitValidationHooks": {
              "type": "boolean"
            }
          }
        },
        "summary": {
          "$ref": "#/definitions/jobSummary"
        }
      }
    }
  },
  "definitions": {
    "sourceDocument": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "documentId",
        "title",
        "type"
      ],
      "properties": {
        "documentId": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "type": {
          "type": "string",
          "enum": [
            "PDF",
            "IMAGE",
            "TEXT"
          ]
        },
        "revision": {
          "type": "string"
        },
        "effectiveDate": {
          "type": "string",
          "format": "date"
        },
        "sha256": {
          "type": "string",
          "pattern": "^[A-Fa-f0-9]{64}$"
        },
        "pageCount": {
          "type": "integer",
          "minimum": 1
        },
        "uriHint": {
          "type": "string"
        }
      }
    },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifactId",
        "kind",
        "documentId",
        "pathHint"
      ],
      "properties": {
        "artifactId": {
          "type": "string"
        },
        "kind": {
          "type": "string",
          "enum": [
            "AI_EXTRACTED_PROCEDURE",
            "AI_EXTRACTED_KNOWLEDGE_UNIT",
            "AI_DRILL_BLUEPRINT",
            "AI_HITBOX_CALLOUT_MAP",
            "AI_EXTRACTION_REPORT"
          ]
        },
        "documentId": {
          "type": "string"
        },
        "pathHint": {
          "type": "string",
          "description": "Where you store it (assets/ai_out/...)."
        },
        "count": {
          "type": "integer",
          "minimum": 1
        },
        "warnings": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "jobSummary": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "proceduresExtracted": {
          "type": "integer",
          "minimum": 0
        },
        "knowledgeUnitsExtracted": {
          "type": "integer",
          "minimum": 0
        },
        "drillsGenerated": {
          "type": "integer",
          "minimum": 0
        },
        "errors": {
          "type": "integer",
          "minimum": 0
        },
        "overallConfidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    }
  }
}
