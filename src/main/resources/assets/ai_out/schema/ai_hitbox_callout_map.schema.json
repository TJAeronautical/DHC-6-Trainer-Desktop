{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://dhc6trainer.app/schema/ai_hitbox_callout_map.schema.json",
  "title": "AI Hitbox + Callout Map",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "meta",
    "mappings"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "enum": [
        "2.0"
      ]
    },
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mapId",
        "createdAtUtc",
        "variant"
      ],
      "properties": {
        "mapId": {
          "type": "string"
        },
        "createdAtUtc": {
          "type": "string",
          "format": "date-time"
        },
        "variant": {
          "type": "string",
          "enum": [
            "LEGACY",
            "G950",
            "BOTH"
          ]
        },
        "sourceDocumentId": {
          "type": "string"
        },
        "sourceProcedureId": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "mappings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/definitions/mapping"
      }
    }
  },
  "definitions": {
    "mapping": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "targetType",
        "targetId",
        "bindings"
      ],
      "properties": {
        "targetType": {
          "type": "string",
          "enum": [
            "EXTRACTED_STEP_ID",
            "PROCEDURE_ID",
            "DRILL_ITEM_ID"
          ]
        },
        "targetId": {
          "type": "string"
        },
        "bindings": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/definitions/binding"
          }
        }
      }
    },
    "binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "bindingType",
        "confidence"
      ],
      "properties": {
        "bindingType": {
          "type": "string",
          "enum": [
            "HITBOX_FOCUS",
            "HITBOX_REQUIRED",
            "CALLOUT",
            "CAS_EXPECTED",
            "ANNUNCIATOR_EXPECTED"
          ]
        },
        "hitbox": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "hitboxId": {
              "type": "string",
              "description": "Must exist in hitboxes_legacy.json or hitboxes_g950.json."
            },
            "highlightStyle": {
              "type": "string",
              "enum": [
                "PULSE",
                "OUTLINE",
                "SHADE",
                "FLASH"
              ]
            }
          }
        },
        "callout": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "crewRole": {
              "type": "string",
              "enum": [
                "PF",
                "PM",
                "BOTH",
                "PIC"
              ]
            },
            "text": {
              "type": "string"
            },
            "timing": {
              "type": "string",
              "enum": [
                "IMMEDIATE",
                "ON_FOCUS",
                "ON_COMPLETE",
                "DELAYED"
              ]
            },
            "audioKey": {
              "type": "string"
            }
          }
        },
        "casExpected": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "message": {
              "type": "string"
            },
            "state": {
              "type": "string",
              "enum": [
                "WARNING",
                "CAUTION",
                "ADVISORY"
              ]
            }
          }
        },
        "annunciatorExpected": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "annunciatorId": {
              "type": "string"
            },
            "state": {
              "type": "string",
              "enum": [
                "ON",
                "OFF",
                "FLASH"
              ]
            }
          }
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "evidence": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "textQuote": {
              "type": "string"
            },
            "page": {
              "type": "integer",
              "minimum": 1
            }
          }
        }
      }
    }
  }
}
